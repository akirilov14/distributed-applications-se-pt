@page "/admin/filmi"
@rendermode InteractiveServer
@inject FilmApiClient FilmClient
@inject AuthStateService AuthStateService
@inject NavigationManager Navigation

<PageTitle>Управление на филми – CineBook</PageTitle>

<div class="container mt-4">
    @if (!AuthStateService.IsAdmin)
    {
        <div class="alert alert-danger">Нямате достъп.</div>
    }
    else
    {

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Управление на филми</h2>
        <a href="admin/filmi/nov" class="btn btn-success">+ Добави филм</a>
    </div>

    @if (isLoading)
    {
        <div class="text-center py-5"><div class="spinner-border text-primary"></div></div>
    }
    else if (pagedResult is null || pagedResult.TotalCount == 0)
    {
        <div class="alert alert-info">Няма филми в базата данни.</div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>ID</th>
                        <th>Заглавие</th>
                        <th>Жанр</th>
                        <th>Режисьор</th>
                        <th>Година</th>
                        <th>Оценка</th>
                        <th>Активен</th>
                        <th>Действия</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var film in pagedResult.Items)
                    {
                        <tr>
                            <td>@film.Id</td>
                            <td>@film.Title</td>
                            <td>@film.Genre</td>
                            <td>@film.Director</td>
                            <td>@film.ReleaseYear</td>
                            <td>⭐ @film.Rating.ToString("0.0")</td>
                            <td>
                                <span class="badge @(film.IsActive ? "bg-success" : "bg-secondary")">
                                    @(film.IsActive ? "Да" : "Не")
                                </span>
                            </td>
                            <td>
                                <div class="d-flex gap-1">
                                    <a href="admin/filmi/edit/@film.Id" class="btn btn-outline-primary btn-sm">Редактирай</a>
                                    <button class="btn btn-outline-danger btn-sm" @onclick="() => ConfirmDelete(film)">Изтрий</button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <nav class="mt-3">
            <ul class="pagination justify-content-center">
                <li class="page-item @(pagedResult.HasPreviousPage ? "" : "disabled")">
                    <button class="page-link" @onclick="() => LoadPage(currentPage - 1)">Предишна</button>
                </li>
                @for (int pageIndex = 1; pageIndex <= pagedResult.TotalPages; pageIndex++)
                {
                    var pageNum = pageIndex;
                    <li class="page-item @(pageNum == currentPage ? "active" : "")">
                        <button class="page-link" @onclick="() => LoadPage(pageNum)">@pageNum</button>
                    </li>
                }
                <li class="page-item @(pagedResult.HasNextPage ? "" : "disabled")">
                    <button class="page-link" @onclick="() => LoadPage(currentPage + 1)">Следваща</button>
                </li>
            </ul>
        </nav>
        <p class="text-center text-muted">Общо @pagedResult.TotalCount филма</p>
    }

    } @* end else IsAdmin *@
</div>

@if (filmToDelete is not null)
{
    <div class="modal show d-block" tabindex="-1" style="background:rgba(0,0,0,0.5)">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header"><h5 class="modal-title">Потвърди изтриване</h5></div>
                <div class="modal-body">Сигурни ли сте, че искате да изтриете „@filmToDelete.Title"?</div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="() => filmToDelete = null">Отказ</button>
                    <button class="btn btn-danger" @onclick="DeleteFilm">Изтрий</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private PagedResult<FilmResponse>? pagedResult;
    private bool isLoading = true;
    private int currentPage = 1;
    private const int PageSize = 15;
    private FilmResponse? filmToDelete;

    protected override async Task OnInitializedAsync()
    {
        if (!AuthStateService.IsAdmin) return;
        await LoadPage(1);
    }

    private async Task LoadPage(int pageNumber)
    {
        isLoading = true;
        currentPage = pageNumber;
        pagedResult = await FilmClient.GetAllAsync(currentPage, PageSize);
        isLoading = false;
    }

    private void ConfirmDelete(FilmResponse film) => filmToDelete = film;

    private async Task DeleteFilm()
    {
        if (filmToDelete is null) return;
        await FilmClient.DeleteAsync(filmToDelete.Id);
        filmToDelete = null;
        await LoadPage(currentPage);
    }
}
