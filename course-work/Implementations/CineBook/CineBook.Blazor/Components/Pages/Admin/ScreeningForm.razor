@page "/admin/prozhekcii/nova"
@page "/admin/prozhekcii/edit/{Id:int}"
@rendermode InteractiveServer
@inject ScreeningApiClient ScreeningClient
@inject FilmApiClient FilmClient
@inject AuditoriumApiClient AuditoriumClient
@inject AuthStateService AuthStateService
@inject NavigationManager Navigation

<PageTitle>@(isEditing ? "Редактиране" : "Добавяне") на прожекция – CineBook</PageTitle>

<div class="container mt-4" style="max-width:600px;">
    @if (!AuthStateService.IsAdmin)
    {
        <div class="alert alert-danger">Нямате достъп.</div>
    }
    else
    {

    <h2>@(isEditing ? "Редактиране на прожекция" : "Добавяне на прожекция")</h2>

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger">@errorMessage</div>
    }

    @if (isLoading)
    {
        <div class="text-center py-4"><div class="spinner-border text-primary"></div></div>
    }
    else
    {
        <EditForm Model="formModel" OnValidSubmit="SaveScreening" FormName="screeningForm">
            <DataAnnotationsValidator />

            <div class="mb-3">
                <label class="form-label">Филм <span class="text-danger">*</span></label>
                <InputSelect class="form-select" @bind-Value="formModel.FilmId">
                    <option value="0">-- Изберете филм --</option>
                    @foreach (var film in films)
                    {
                        <option value="@film.Id">@film.Title (@film.DurationMinutes мин.)</option>
                    }
                </InputSelect>
                <ValidationMessage For="() => formModel.FilmId" class="text-danger" />
            </div>

            <div class="mb-3">
                <label class="form-label">Зала <span class="text-danger">*</span></label>
                <InputSelect class="form-select" @bind-Value="formModel.AuditoriumId">
                    <option value="0">-- Изберете зала --</option>
                    @foreach (var auditorium in auditoriums)
                    {
                        <option value="@auditorium.Id">@auditorium.Name</option>
                    }
                </InputSelect>
                <ValidationMessage For="() => formModel.AuditoriumId" class="text-danger" />
            </div>

            <div class="mb-3">
                <label class="form-label">Начален час <span class="text-danger">*</span></label>
                <InputDate Type="InputDateType.DateTimeLocal" class="form-control" @bind-Value="formModel.StartTime" />
                <ValidationMessage For="() => formModel.StartTime" class="text-danger" />
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label">Базова цена (лв.)</label>
                    <InputNumber class="form-control" @bind-Value="formModel.BasePrice" />
                    <ValidationMessage For="() => formModel.BasePrice" class="text-danger" />
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label">Език <span class="text-danger">*</span></label>
                    <InputText class="form-control" @bind-Value="formModel.Language" placeholder="Български, Английски..." />
                    <ValidationMessage For="() => formModel.Language" class="text-danger" />
                </div>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label">Субтитри</label>
                    <InputText class="form-control" @bind-Value="formModel.Subtitles" placeholder="Български..." />
                    <ValidationMessage For="() => formModel.Subtitles" class="text-danger" />
                </div>
                <div class="col-md-6 mb-3 d-flex align-items-end">
                    <div class="form-check form-switch">
                        <InputCheckbox class="form-check-input" @bind-Value="formModel.Is3D" id="is3d" />
                        <label class="form-check-label" for="is3d">3D прожекция</label>
                    </div>
                </div>
            </div>

            @if (isEditing)
            {
                <div class="mb-3 form-check">
                    <InputCheckbox class="form-check-input" @bind-Value="updateIsActive" id="isActive" />
                    <label class="form-check-label" for="isActive">Активна</label>
                </div>
            }

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary" disabled="@isSaving">
                    @if (isSaving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                    Запази
                </button>
                <a href="prozhekcii" class="btn btn-outline-secondary">Отказ</a>
            </div>
        </EditForm>
    }
    } @* end else IsAdmin *@
</div>

@code {
    [Parameter] public int? Id { get; set; }

    private CreateScreeningRequest formModel = new() { StartTime = DateTime.UtcNow.AddDays(1) };
    private bool updateIsActive = true;
    private bool isEditing => Id.HasValue;
    private bool isLoading = true;
    private bool isSaving = false;
    private string? errorMessage;
    private List<FilmResponse> films = [];
    private List<AuditoriumResponse> auditoriums = [];

    protected override async Task OnInitializedAsync()
    {
        if (!AuthStateService.IsAdmin) { isLoading = false; return; }

        var filmsResult = await FilmClient.GetAllAsync(1, 200);
        films = filmsResult?.Items.ToList() ?? [];

        var auditoriumsResult = await AuditoriumClient.GetAllAsync(1, 100);
        auditoriums = auditoriumsResult?.Items.ToList() ?? [];

        if (isEditing)
        {
            var screening = await ScreeningClient.GetByIdAsync(Id!.Value);
            if (screening is not null)
            {
                formModel.FilmId = screening.FilmId;
                formModel.AuditoriumId = screening.AuditoriumId;
                formModel.StartTime = screening.StartTime;
                formModel.BasePrice = screening.BasePrice;
                formModel.Is3D = screening.Is3D;
                formModel.Language = screening.Language;
                formModel.Subtitles = screening.Subtitles;
                updateIsActive = screening.IsActive;
            }
        }

        isLoading = false;
    }

    private async Task SaveScreening()
    {
        isSaving = true;
        errorMessage = null;

        if (isEditing)
        {
            var request = new UpdateScreeningRequest
            {
                FilmId = formModel.FilmId,
                AuditoriumId = formModel.AuditoriumId,
                StartTime = formModel.StartTime,
                BasePrice = formModel.BasePrice,
                Is3D = formModel.Is3D,
                Language = formModel.Language,
                Subtitles = formModel.Subtitles,
                IsActive = updateIsActive
            };
            var result = await ScreeningClient.UpdateAsync(Id!.Value, request);
            if (result is null) errorMessage = "Грешка при запазване.";
            else Navigation.NavigateTo("prozhekcii");
        }
        else
        {
            var result = await ScreeningClient.CreateAsync(formModel);
            if (result is null) errorMessage = "Грешка при запазване.";
            else Navigation.NavigateTo("prozhekcii");
        }

        isSaving = false;
    }
}
